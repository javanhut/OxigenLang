// Tests for the os stdlib module.
// Filesystem checks below are relative to the current working directory, so run
// this from the repository root:  oxigen test example/os_test.oxi

introduce os

<test>("environment variables") {
    os.env_set("OXIGEN_TEST", "hello from oxigen")
    expect(os.env_get("OXIGEN_TEST")).eq("hello from oxigen")
}

<test>("filesystem checks") {
    expect(os.is_dir("stdlib")).truthy()
    expect(os.is_file("Cargo.toml")).truthy()
    expect(os.is_dir("definitely_not_a_real_dir_xyz")).falsy()
}

<test>("exec a command") {
    result <map> := os.exec("echo hello from shell")
    expect(result["code"]).eq(0)
}

<test>("mkdir and rmdir") {
    os.mkdir("/tmp/oxigen_test_dir/nested")
    expect(os.is_dir("/tmp/oxigen_test_dir/nested")).truthy()
    os.rmdir("/tmp/oxigen_test_dir")
    expect(os.is_dir("/tmp/oxigen_test_dir")).falsy()
}
