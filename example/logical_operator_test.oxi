x := 90
y := 20

// Normal truthy or: x is 90 (truthy), short-circuits to True
option { x or y == 10 -> println("truthy: True"), println("truthy: False") }

// Distributed comparison: does x or y equal 10?
// (x or y) == 10  →  x == 10 or y == 10  →  False
option { (x or y) == 10 -> println("distributed: True"), println("distributed: False") }

// With y = 10: (x or y) == 10  →  x == 10 or y == 10  →  True
y := 10
option { (x or y) == 10 -> println("y is 10: True"), println("y is 10: False") }

// Distributed and: both must satisfy the comparison
a := 5
b := 5
option { (a and b) == 5 -> println("both 5: True"), println("both 5: False") }

b := 3
option { (a and b) == 5 -> println("both 5 after: True"), println("both 5 after: False") }

// Chaining: (x or y or z) == val
z := 42
option { (x or y or z) == 42 -> println("one is 42: True"), println("one is 42: False") }

// Works with all comparison operators
option { (a or b) > 4 -> println("one > 4: True"), println("one > 4: False") }
option { (a and b) > 4 -> println("both > 4: True"), println("both > 4: False") }

// Value on either side
option { 5 == (a or b) -> println("5 in group: True"), println("5 in group: False") }
