// Tests for short-circuit and distributed logical operators.
// Run with:  oxigen test example/logical_operator_test.oxi

<test>("short-circuit or") {
    x <int> := 90
    y <int> := 20
    // `x or y == 10` is `x or (y == 10)`; x is truthy so the whole thing is truthy.
    expect(x or y == 10).truthy()
}

<test>("distributed comparison over a group") {
    x <int> := 90
    y <int> := 20
    // `(x or y) == 10` distributes: `x == 10 or y == 10` -> False
    expect((x or y) == 10).falsy()

    y := 10
    // now `x == 10 or y == 10` -> True
    expect((x or y) == 10).truthy()
}

<test>("distributed and") {
    a <int> := 5
    b <int> := 5
    expect((a and b) == 5).truthy()
    b := 3
    expect((a and b) == 5).falsy()
}

<test>("chaining and comparison operators") {
    x <int> := 90
    y <int> := 10
    z <int> := 42
    expect((x or y or z) == 42).truthy()

    a <int> := 5
    b <int> := 3
    expect((a or b) > 4).truthy()
    expect((a and b) > 4).falsy()
    expect(5 == (a or b)).truthy()
}
