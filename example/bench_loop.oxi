// Tight integer loop — single function, locals only, no recursion.
// Maximally favors the inline int fast path since almost every opcode
// in the body is GetLocal/SetLocal or int arithmetic.
fun loop_sum(n) {
    total := 0
    i := 1
    repeat when i <= n {
        total := total + i * 2
        i := i + 1
    }
    total
}

loop_sum(1000000)
