// Tests for type conversion and the time, random, path, and json stdlib modules.
// Run with:  oxigen test example/new_stdlib_test.oxi

introduce time
introduce random
introduce path
introduce json
introduce io
introduce os

<test>("type conversion") {
    expect(int("42")).eq(42)
    expect(int("3.14")).eq(3)
    expect(int(True)).eq(1)
    expect(float("3.14")).eq(3.14)
    expect(float(42)).eq(42.0)
}

<test>("time is monotonic") {
    expect(time.now()).gt(0)
    start <int> := time.monotonic()
    time.sleep(5)
    end <int> := time.monotonic()
    expect(end).gte(start)
}

<test>("random is seeded and bounded") {
    random.seed(42)
    expect(random.rand_int(1, 10)).gte(1)
    expect(random.rand_int(1, 10)).lte(10)
    choice <str> := random.choice(["a", "b", "c"])
    expect(["a", "b", "c"]).contains(choice)
}

<test>("path manipulation") {
    expect(path.join(["/home", "user", "file.txt"])).eq("/home/user/file.txt")
    expect(path.ext("document.pdf")).eq("pdf")
    expect(path.filename("/home/user/document.pdf")).eq("document.pdf")
    expect(path.parent("/home/user/document.pdf")).eq("/home/user")
    expect(path.stem("document.pdf")).eq("document")
    expect(path.is_absolute("/home")).truthy()
    expect(path.is_absolute("relative/path")).falsy()
}

<test>("json array roundtrip") {
    arr <array> := [1, 2, 3, "hello", True, None]
    io.write_file("/tmp/oxigen_test.json", json.stringify(arr))
    read_back <array> := json.parse(io.read_file("/tmp/oxigen_test.json"))
    expect(read_back[0]).eq(1)
    expect(read_back[3]).eq("hello")
    os.remove_file("/tmp/oxigen_test.json")

    parsed <array> := json.parse("[10, 20, 30]")
    expect(parsed[1]).eq(20)
}
