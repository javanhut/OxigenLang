// Tests for local (relative) module imports. Imports `mylib.oxi` from this
// same directory. Run with:  oxigen test example/local_import_test.oxi

introduce .mylib
introduce {greet, PI} from .mylib

<test>("namespaced local import") {
    expect(mylib.greet("Oxigen")).eq("Hello, Oxigen!")
    expect(mylib.add(10, 20)).eq(30)
    expect(mylib.PI).eq(3.14159)
}

<test>("selective local import") {
    expect(greet("World")).eq("Hello, World!")
    expect(PI).eq(3.14159)
}
