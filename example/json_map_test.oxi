// Tests for the json stdlib module (object <-> map roundtrips through a file).
// Run with:  oxigen test example/json_map_test.oxi

introduce json
introduce io
introduce os

<test>("json roundtrip with a map") {
    io.write_file("/tmp/oxi_test.json", json.stringify({"name": "Oxigen", "version": 1, "active": True}))
    data <map> := json.parse(io.read_file("/tmp/oxi_test.json"))
    expect(data["name"]).eq("Oxigen")
    expect(data["version"]).eq(1)
    expect(data["active"]).truthy()
    os.remove_file("/tmp/oxi_test.json")
}

<test>("nested json objects and arrays") {
    nested_json <str> := json.stringify({"user": {"name": "Javan", "age": 25}, "scores": [90, 85, 100]})
    io.write_file("/tmp/oxi_test2.json", nested_json)
    nested <map> := json.parse(io.read_file("/tmp/oxi_test2.json"))
    expect(nested["user"]["name"]).eq("Javan")
    expect(nested["user"]["age"]).eq(25)
    expect(nested["scores"][0]).eq(90)
    expect(nested["scores"][2]).eq(100)
    os.remove_file("/tmp/oxi_test2.json")
}
