struct Array {
  data <array>
}


Array contains {
  fun append(value) {
    data := push(data, value)
  }
  fun pop() {
    temp <array>
    pos <int>
    repeat when pos < len(data) - 1 {
        temp := push(temp, data[pos])
        pos++
    }
    popped_val := last(data)
    data := temp
    popped_val
  }

  fun print() {
    println(data)
  }

}

arr <Array>
arr.append(10)
arr.append(20)
arr.append(30)
arr.print()
x := arr.pop()
println("Popped: ",x)
arr.print()
