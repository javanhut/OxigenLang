// Stream an LLM response token by token.
//
// POSTs a prompt to a streaming model endpoint and reads the newline-delimited
// JSON (NDJSON) reply one line at a time with net.read_line. Each line is
// {"response": "tok", "done": false}; the last has "done": true.
//
// Targets a local Ollama (https://ollama.com — `ollama run llama3` first).
// Change the url / model / body for any other NDJSON streaming API.
//
// Run:  oxigen example/llm_stream.oxi

introduce net
introduce json
introduce strings

main {
    payload := json.stringify({"model": "llama3", "prompt": "Say hello in five words."})
    s := net.stream_post("http://localhost:11434/api/generate", payload)

    text <str> := ""
    done := False
    repeat unless done {
        line := strings.trim(net.read_line(s))   // one whole JSON object, or "" at EOF
        option {
            line == "" -> { done = True },
            {
                obj := json.parse(line)
                text = text + obj["response"]
                print(obj["response"])           // live, no newline
                done = obj["done"]
            }
        }
    }
    net.close(s)
    println("")
    println("--- captured {len(text)} chars ---")
}
