// Nested integer loop — outer×inner iterations, pure locals + arithmetic.
// Favors the JIT's inline int fast path and SetLocal/GetLocal inlining.
fun nested_sum(n) {
    total := 0
    i := 1
    repeat when i <= n {
        j := 1
        repeat when j <= n {
            total := total + i * j
            j := j + 1
        }
        i := i + 1
    }
    total
}

nested_sum(500)
