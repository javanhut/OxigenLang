introduce math

<test>("constants") {
    expect(math.PI).gt(3.14)
    expect(math.PI).lt(3.15)
    expect(math.TAU).gt(6.28)
    expect(math.E).gt(2.71)
}

<test>("gcd and lcm") {
    expect(math.gcd(12, 18)).eq(6)
    expect(math.gcd(0, 5)).eq(5)
    expect(math.lcm(4, 6)).eq(12)
    expect(math.lcm(0, 5)).eq(0)
}

<test>("factorial") {
    expect(math.factorial(5)).eq(120)
    expect(math.factorial(0)).eq(1)
    expect(math.factorial(-1)).is_error()
}

<test>("even and odd") {
    expect(math.is_even(4)).truthy()
    expect(math.is_even(3)).falsy()
    expect(math.is_odd(3)).truthy()
}

<test>("trunc, hypot, fmod") {
    expect(math.trunc(3.7)).eq(3.0)
    expect(math.trunc(-3.7)).eq(-3.0)
    expect(math.hypot(3, 4)).eq(5.0)
    expect(math.fmod(7.5, 2.0)).eq(1.5)
}

<test>("trigonometry") {
    expect(math.sin(0)).eq(0.0)
    expect(math.cos(0)).eq(1.0)
    expect(math.tan(0)).eq(0.0)
    expect(math.atan2(1, 1)).eq(0.7853981633974483)
}

<test>("exponential and logarithmic") {
    expect(math.exp(0)).eq(1.0)
    expect(math.round(math.ln(math.E))).eq(1)
    expect(math.round(math.log10(1000))).eq(3)
    expect(math.round(math.log2(8))).eq(3)
}

<test>("float power") {
    expect(math.powf(2, 10)).eq(1024.0)
    expect(math.powf(2, 0.5)).eq(1.4142135623730951)
    expect(math.round(math.powf(9, 0.5))).eq(3)
}
